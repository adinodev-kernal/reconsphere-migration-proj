{
  "module": "vendor_master",
  "sap_table": "LFA1",
  "description": "SAP Vendor Master Data — General Section",
  "fields": {
    "VENDOR_CODE": {
      "required": true,
      "pattern": "^[A-Z0-9]{4,10}$",
      "unique": true,
      "notes": "4-10 uppercase alphanumeric. SAP internal number or external number range."
    },
    "VENDOR_NAME": {
      "required": true,
      "max_length": 35,
      "casing": "title",
      "notes": "Maps to LFA1-NAME1. Max 35 chars. Title case."
    },
    "COUNTRY": {
      "required": true,
      "allowed_values_ref": "iso_countries.json",
      "notes": "ISO 3166-1 alpha-2. E.g. IN, US, DE, GB."
    },
    "CITY": {
      "required": false,
      "max_length": 35,
      "casing": "title",
      "notes": "Maps to LFA1-ORT01."
    },
    "POSTAL_CODE": {
      "required": false,
      "length_if": { "field": "COUNTRY", "value": "IN", "length": 6 },
      "notes": "India: exactly 6 digits. Other countries vary."
    },
    "STREET": {
      "required": false,
      "max_length": 35,
      "notes": "Maps to LFA1-STRAS."
    },
    "PAYMENT_TERMS": {
      "required": true,
      "allowed_values": ["NET30", "NET45", "NET60", "NET90", "IMMEDIATE", "NET15"],
      "notes": "Must match payment terms configured in SAP (T052)."
    },
    "CURRENCY": {
      "required": true,
      "allowed_values_ref": "iso_currencies.json",
      "notes": "ISO 4217. E.g. INR, USD, EUR."
    },
    "BANK_KEY": {
      "required": false,
      "pattern": "^[A-Z]{4}0[A-Z0-9]{6}$",
      "notes": "RBI IFSC format: 4 alpha + 0 + 6 alphanumeric. E.g. SBIN0001234."
    },
    "TAX_NUMBER": {
      "required_if": { "field": "COUNTRY", "value": "IN" },
      "pattern": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$",
      "notes": "GSTIN format for India. Required when COUNTRY=IN."
    },
    "EMAIL": {
      "required": false,
      "pattern": "^[\\w._%+\\-]+@[\\w.\\-]+\\.[a-zA-Z]{2,}$",
      "notes": "Standard email format."
    },
    "PHONE": {
      "required": false,
      "pattern": "^[+]?[0-9\\s\\-]{7,15}$",
      "notes": "Phone number. Optional + prefix. 7-15 digits."
    },
    "ACCOUNT_GROUP": {
      "required": false,
      "allowed_values": ["KRED", "LIEF", "CPD"],
      "notes": "SAP vendor account group."
    },
    "RECONCILIATION_ACCOUNT": {
      "required": false,
      "pattern": "^[0-9]{6,10}$",
      "notes": "G/L reconciliation account number."
    }
  }
}